# ── Copy Output to Clipboard (cco) ────────────────────────────
# Usage:  cco <command> [args]   — runs command, shows output, copies to clipboard
cco() {
    [ -z "$*" ] && { echo "[ERROR] Usage: cco <command> [args]" >&2; return 1; }
    local full_cmd="$*" working_dir output exit_code
    working_dir=$(pwd) || working_dir="UNKNOWN"
    output=$("$@" 2>&1)
    exit_code=$?
    echo "$output"
    if [ ! -f "/mnt/c/Windows/System32/clip.exe" ]; then
        log_warn "Windows clipboard not available (clip.exe not found)"
        return $exit_code
    fi
    local formatted="inside <${working_dir}>
executed command: ${full_cmd}
output:
${output}"
    [ $exit_code -ne 0 ] && formatted+="
[Errors]: Exit code ${exit_code}"
    printf '%s' "$formatted" | /mnt/c/Windows/System32/clip.exe 2>/dev/null \
        || log_warn "Failed to copy output to clipboard"
    return $exit_code
}
complete -F _command cco 2>/dev/null || complete -c cco

# ── Modern Search (sfind / search) ───────────────────────────
# Usage: sfind [-p <path>] <term> [file|folder|all]
sfind() {
    local search_path="$HOME"
    local OPTIND opt
    while getopts ":p:" opt; do
        case $opt in
            p) search_path="$OPTARG" ;;
            \?) echo -e "\033[1;31m✖ Invalid option -$OPTARG\033[0m"; return 1 ;;
            :)  echo -e "\033[1;31m✖ Option -$OPTARG requires an argument\033[0m"; return 1 ;;
        esac
    done
    shift $((OPTIND-1))

    local search_term="$1" search_type="${2:-all}"
    if [ -z "$search_term" ]; then
        echo -e "\033[1;31m✖ Provide a search term.\033[0m"
        echo -e "  \033[1;37mUsage:\033[0m \033[1;36msfind\033[0m \033[90m[-p <path>]\033[0m \033[33m<term>\033[0m \033[90m[file|folder|all]\033[0m"
        echo -e "  \033[1;37mExamples:\033[0m"
        echo -e "    \033[36msfind config\033[0m              \033[90m# search files and folders in ~\033[0m"
        echo -e "    \033[36msfind -p /etc bash file\033[0m   \033[90m# search only files in /etc\033[0m"
        return 1
    fi

    echo -e "\n  \033[1;35m🔍 SEARCHING ${search_path}\033[0m \033[90m──────────────────────────────────────────────\033[0m"
    echo -e "  \033[1;37mTerm:\033[0m \033[1;32m$search_term\033[0m  \033[90m|\033[0m  \033[1;37mType:\033[0m \033[1;34m$search_type\033[0m\n"

    local stype abs_path output found=0
    stype="$(echo "$search_type" | tr '[:upper:]' '[:lower:]')"
    abs_path=$(realpath "$search_path" 2>/dev/null || echo "$search_path")

    # Prefer fdfind (Debian/Ubuntu) then fd
    local fd_cmd=""
    if type -P fdfind >/dev/null 2>&1; then
        fd_cmd="fdfind"
    elif type -P fd >/dev/null 2>&1; then
        fd_cmd="fd"
    fi

    if [ -n "$fd_cmd" ]; then
        local fd_type=""
        case "$stype" in
            file|f|files)                           fd_type="-t f" ;;
            folder|dir|d|folders|dirs|directories)  fd_type="-t d" ;;
        esac
        output=$("$fd_cmd" $fd_type -i -H "$search_term" "$abs_path" --color=never 2>/dev/null)
    else
        local find_args=()
        case "$stype" in
            file|f|files)                           find_args=(-type f -iname "*${search_term}*") ;;
            folder|dir|d|folders|dirs|directories)  find_args=(-type d -iname "*${search_term}*") ;;
            *)                                      find_args=(-iname "*${search_term}*") ;;
        esac
        output=$(find "$abs_path" "${find_args[@]}" 2>/dev/null | grep -i "$search_term")
    fi

    if [ -n "$output" ]; then
        found=1
        echo "$output" | awk -v term="$search_term" '
        BEGIN {
            term_lower=tolower(term); term_len=length(term)
            c_match="\033[1;36m"; c_base="\033[1;37m"; c_dim="\033[2;90m"; c_rst="\033[0m"
        }
        function hl(str, bc,   res,sl,idx,p1,ms) {
            if (term=="") return bc str c_rst
            res=""; sl=tolower(str); idx=index(sl,term_lower)
            while (idx>0) {
                p1=substr(str,1,idx-1); ms=substr(str,idx,term_len)
                res=res bc p1 c_match ms
                str=substr(str,idx+term_len); sl=substr(sl,idx+term_len)
                idx=index(sl,term_lower)
            }
            return res bc str c_rst
        }
        {
            paths[NR]=$0; n=split($0,p,"/"); b=p[n]
            if (b=="") b=p[n-1]"/"
            bases[NR]=b; l=length(b); if(l>mx) mx=l
        }
        END {
            for(i=1;i<=NR;i++) {
                b=bases[i]; pad=""; for(j=0;j<mx-length(b);j++) pad=pad" "
                printf "  %s%s   %s\n", hl(b,c_base), pad, hl(paths[i],c_dim)
            }
        }'
    fi

    [ $found -eq 0 ] && echo -e "  \033[3m\033[90mNo matches found.\033[0m"
    echo -e "\n  \033[1;32m✨ Done.\033[0m \033[90m────────────────────────────────────────────────────\033[0m\n"
}

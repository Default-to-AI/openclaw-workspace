                in && /^## /{exit}
                in && /^[[:space:]]*- \[ \]/{print; c++; if(c>=3) exit}
            ' "$VAULT_INBOX" 2>/dev/null)

            if [ -n "$jinx_preview" ]; then
                echo -e "  ${R_B_YLW}⚡️ Jinx${R_RST}"
                echo "$jinx_preview" | sed 's/^/    /'
            fi
            if [ -n "$robert_preview" ]; then
                echo -e "  ${R_B_YLW}🧑‍💻 Robert${R_RST}"
                echo "$robert_preview" | sed 's/^/    /'
            fi
        fi

        # 2) Master triage section (preferred)
        if [ -f "$VAULT_MASTER" ]; then
            local master_preview
            master_preview=$(awk '
                BEGIN{in=0; c=0}
                /^## 📥 Inbox \(triage pending\)/{in=1; next}
                in && /^## /{exit}
                in && /^[[:space:]]*- \[ \]/{print; c++; if(c>=5) exit}
            ' "$VAULT_MASTER" 2>/dev/null)

            if [ -n "$master_preview" ]; then
                echo -e "  ${R_B_YLW}🧭 Master (triage)${R_RST}"
                echo "$master_preview" | sed 's/^/    /'
            fi
        fi
    }
fi
alias cx='clear && show_banner'

[[ $- == *i* ]] && cx


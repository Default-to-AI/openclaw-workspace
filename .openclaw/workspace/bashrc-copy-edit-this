# ── Prompt Functions ──────────────────────────────────────────
parse_git_branch() {
    local branch
    command -v git >/dev/null 2>&1 || return 0
    branch=$(git branch 2>/dev/null | grep '^\*' | sed 's/* //')
    [ -z "$branch" ] && return 0
    if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
        echo " (${branch}*)"
    else
        echo " (${branch})"
    fi
}

oc_status() {
    local port="18789"
    if [ -f "$HOME/.openclaw/openclaw.json" ] && command -v jq >/dev/null 2>&1; then
        local config_port
        config_port=$(jq -r '.gateway.port // empty' "$HOME/.openclaw/openclaw.json" 2>/dev/null)
        [ -n "$config_port" ] && port="$config_port"
    fi
    if ! command -v curl >/dev/null 2>&1; then
        echo -e "\033[2;37mUNCHECKED ●\033[0m"
    elif curl -s --max-time 1 "http://127.0.0.1:${port}/" >/dev/null 2>&1; then
        echo -e "\033[1;32mREADY ●\033[0m"
    else
        echo -e "\033[2;37mUNREACHABLE ●\033[0m"
    fi
}

dashboard_status() {
    local result="\033[2;37mOFFLINE ●\033[0m"
    command -v tailscale >/dev/null 2>&1 || { echo -e "$result"; return 0; }
    command -v curl      >/dev/null 2>&1 || { echo -e "$result"; return 0; }
    local ts_url
    ts_url=$(tailscale serve status 2>/dev/null | grep -oP 'https://[a-zA-Z0-9.-]+\.ts\.net' | head -1)
    if [ -n "$ts_url" ] && curl -skf --max-time 1 "${ts_url}/healthz" >/dev/null 2>&1; then
        result="\033[1;32mONLINE ●\033[0m"
    fi
    echo -e "$result"
}

prompt_context() {
    local cwd="$PWD"
    if   [[ "$cwd" == "$HOME/.openclaw"* ]]; then
        echo -e "${R_GRA}~${R_RST} ${R_B_RED}[🦞 OpenClaw]${R_RST}"
    elif [[ "$cwd" == "$HOME" ]]; then
        echo -e "${R_GRA}~${R_RST} \033[1;33m[🏠 Home]\033[0m"
    elif [[ "$cwd" == /mnt/c/Users* ]]; then
        echo -e "${R_GRA}~${R_RST} ${R_B_CYN}[💾 Windows]${R_RST}"
    fi
}

prompt_path() {
    local dir base
    dir=$(dirname "$PWD" | sed "s|^$HOME|🏠|")
    base=$(basename "$PWD")
    if [[ "$PWD" == "/" ]]; then
        echo -e "\033[1;37m/\033[0m"
    elif [[ "$PWD" == "$HOME" ]]; then
        echo -e "\033[1;37m🏠\033[0m"
    else
        dir="${dir//\// / }"
        dir="${dir# }"
        if [[ "$dir" == "/" ]]; then
            echo -e "\033[2;37m/ \033[0m\033[1;37m${base}\033[0m"
        else
            echo -e "\033[2;37m${dir} / \033[0m\033[1;37m${base}\033[0m"
        fi
    fi
}

draw_prompt_separator() {
    echo ""
    local line
    printf -v line '%*s' "$COLUMNS" ''
    echo -e "\033[0;90m${line// /─}\033[0m"
}


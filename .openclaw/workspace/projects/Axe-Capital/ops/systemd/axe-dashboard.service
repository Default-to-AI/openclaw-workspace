[Unit]
Description=Axe Capital Dashboard
After=network-online.target axe-api.service
Wants=axe-api.service

[Service]
Type=simple
WorkingDirectory=%h/.openclaw/workspace/projects/Axe-Capital/step6-dashboard
Environment=NODE_ENV=development
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0 --port 5173 --strictPort
Restart=always
RestartSec=5

[Install]
WantedBy=default.target

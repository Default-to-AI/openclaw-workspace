[Unit]
Description=Axe Capital Daily Portfolio Refresh
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/.openclaw/workspace/projects/Axe-Capital/step5-portfolio-tracking
Environment=PYTHONUNBUFFERED=1
ExecStart=%h/.openclaw/workspace/projects/Axe-Capital/.venv/bin/python -m axe_portfolio.cli
StandardOutput=journal
StandardError=journal
